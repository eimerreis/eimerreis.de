# Core site identity
SITE_NAME=eimerreis.de
SITE_TAGLINE=Writing about frontend craft, internet culture, and the things worth replaying.
SITE_DESCRIPTION=A personal website collecting notes and monthly playlists by Eimer Reis.
NEXT_PUBLIC_SITE_URL=https://eimerreis.de

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=eimerreis.de

# Notion content
NOTION_API_KEY=secret_XXXXXXXXXXXXXXXXXXXXXXXX
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAGES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Spotify playlists
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_USER_ID=eimerreis

# Spotify admin automation
SPOTIFY_ADMIN_ACCOUNT_ID=eimerreis
SPOTIFY_ADMIN_REDIRECT_URI=http://localhost:3000/api/admin/spotify/callback
SPOTIFY_ADMIN_TOKEN_SECRET=replace-with-a-long-random-secret
SPOTIFY_ADMIN_SESSION_SECRET=replace-with-a-different-long-random-secret
SPOTIFY_ADMIN_TOKEN_KEY=spotify:admin:token
REDIS_URL=redis://default:password@host:6379
SPOTIFY_CRON_SECRET=replace-with-a-long-random-secret
